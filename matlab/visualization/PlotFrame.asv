function PlotFrame(M)
    origin = M(1:3, 4);
    x = M(1:3, 1);
    y = M(1:3, 2);
    z = M(1:3, 3);

    hold on;

    quiver3(origin(1),origin(2), origin(3), x(1), x(2), x(3), 0, 'r', 'LineWidth', 2, 'MaxHeadSize',0.1);
    quiver3(origin(1),origin(2), origin(3), y(1), y(2), y(3), 0, 'g', 'LineWidth', 2, 'MaxHeadSize',0.1);
    quiver3(origin(1),origin(2), origin(3), z(1), z(2), z(3), 'b', 'LineWidth', 2, 'MaxHeadSize',0.1);
end